# ══════════════════════════════════════════════════════════════════
#  Which platform(s) to run (comma-separated):
#    telegram | whatsapp | slack | both | all
#  Examples:
#    BOT_MODE=telegram               (default)
#    BOT_MODE=slack
#    BOT_MODE=telegram,slack
#    BOT_MODE=all                    (all three)
# ══════════════════════════════════════════════════════════════════
BOT_MODE=telegram

# ─── Claude settings (shared by both platforms) ───────────────────

# cli  → your locally installed `claude` CLI (no API key needed)
# api  → Anthropic REST API (needs ANTHROPIC_API_KEY)
CLAUDE_MODE=cli

# API mode settings (only used when CLAUDE_MODE=api)
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096

# Shared system prompt (one line, no newlines)
SYSTEM_PROMPT=You are a helpful AI assistant. Be concise unless asked for detail.

# CLI working directory (default: home directory)
CLAUDE_CLI_WORK_DIR=/Users/you

# Extra directories claude can access (comma-separated)
CLAUDE_CLI_ADD_DIRS=/Users/you/projects,/Users/you/documents

# Permission mode: empty=default | acceptEdits | auto | bypassPermissions
CLAUDE_CLI_PERMISSION_MODE=auto

# Default CLI model: haiku | sonnet | opus
CLAUDE_CLI_MODEL=sonnet

# Timeout in seconds
CLAUDE_TIMEOUT=180

# Rate limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# SQLite database path (default: bot.db in project dir)
# DB_PATH=/path/to/bot.db

# ══════════════════════════════════════════════════════════════════
#  TELEGRAM — needed when BOT_MODE=telegram or BOT_MODE=both
# ══════════════════════════════════════════════════════════════════

# Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Comma-separated Telegram numeric user IDs to whitelist (empty = allow all)
TELEGRAM_ALLOWED_USER_IDS=

# ══════════════════════════════════════════════════════════════════
#  WHATSAPP — needed when BOT_MODE=whatsapp or BOT_MODE=both
#  Uses Green API (free tier — 1 500 msg/month, no Meta account needed)
#   1. Sign up at https://console.green-api.com
#   2. Create instance → Scan QR with your WhatsApp phone
#   3. Copy Instance ID and API Token below
# ══════════════════════════════════════════════════════════════════

GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# Comma-separated phone numbers in E.164 WITHOUT leading + (empty = allow all)
# e.g. WHATSAPP_ALLOWED_NUMBERS=14155552671,919876543210
WHATSAPP_ALLOWED_NUMBERS=

# Polling interval in seconds
POLL_INTERVAL_SECONDS=2

# ══════════════════════════════════════════════════════════════════
#  SLACK — needed when BOT_MODE=slack or BOT_MODE includes slack
#
#  Setup (~5 min):
#   1. https://api.slack.com/apps → Create New App → From scratch
#   2. Settings → Socket Mode → Enable → Create App-Level Token
#      Scopes: connections:write  →  copy the xapp-... token
#   3. OAuth & Permissions → Bot Token Scopes:
#        chat:write, channels:history, groups:history,
#        im:history, im:write, app_mentions:read, reactions:write
#   4. Event Subscriptions → Enable → Subscribe to bot events:
#        message.im, message.channels, message.groups, app_mention
#   5. Install to workspace → copy the xoxb-... Bot Token
#   6. Invite bot to channels: /invite @yourbot
# ══════════════════════════════════════════════════════════════════

# Bot OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=

# App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Comma-separated Slack member IDs to whitelist (empty = allow all)
# Find your ID: click your name in Slack → View profile → three-dot menu → Copy member ID
SLACK_ALLOWED_USER_IDS=

# ══════════════════════════════════════════════════════════════════
#  WATCHDOG — self-improving code monitor (runs as separate service)
#
#  The watchdog tails bot.log, detects errors, and uses Claude to
#  auto-fix issues. Fixes are branched, tested, and rolled back if
#  they cause regressions.
#
#  Install:
#    cp scripts/watchdog.plist ~/Library/LaunchAgents/com.claude.watchdog.plist
#    launchctl load ~/Library/LaunchAgents/com.claude.watchdog.plist
# ══════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════
#  OPENAI — needed for TTS and image generation features
# ══════════════════════════════════════════════════════════════════

OPENAI_API_KEY=

# ─── Text-to-Speech (TTS) ───────────────────────────────────────
TTS_ENABLED=false
TTS_MODEL=tts-1
TTS_VOICE=alloy
# Max characters per TTS request
TTS_MAX_LENGTH=4096

# ─── Image Generation (DALL-E) ──────────────────────────────────
IMAGE_GEN_ENABLED=false
IMAGE_GEN_MODEL=dall-e-3
IMAGE_GEN_SIZE=1024x1024
IMAGE_GEN_QUALITY=standard

# ══════════════════════════════════════════════════════════════════
#  WEB SEARCH — enables /search command
#  Supports Brave Search API or Tavily API
# ══════════════════════════════════════════════════════════════════

WEB_SEARCH_ENABLED=false
# Provider: brave | tavily | auto (auto picks whichever key is set)
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_MAX_RESULTS=5

# Brave Search (free tier: 2000 queries/month)
#   Sign up: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Tavily Search (free tier: 1000 queries/month)
#   Sign up: https://tavily.com/
TAVILY_API_KEY=

# ─── Voice Transcription (Whisper) ───────────────────────────────
TRANSCRIPTION_ENABLED=false
WHISPER_MODEL=whisper-1
# Max audio file size in MB
TRANSCRIPTION_MAX_SIZE_MB=25

# ══════════════════════════════════════════════════════════════════
#  REPLICATE — needed for music and video generation
#  Sign up: https://replicate.com/
# ══════════════════════════════════════════════════════════════════

REPLICATE_API_TOKEN=

# ─── Music Generation (MusicGen via Replicate) ──────────────────
MUSIC_GEN_ENABLED=false
MUSIC_GEN_DURATION=10

# ─── Video Generation (Luma/Minimax via Replicate) ──────────────
VIDEO_GEN_ENABLED=false
VIDEO_GEN_MODEL=luma/ray

# ══════════════════════════════════════════════════════════════════
#  WEB FETCH — readable content extraction from URLs (/fetch)
#  Uses Jina Reader API for best results, or basic HTML stripping
# ══════════════════════════════════════════════════════════════════

WEB_FETCH_ENABLED=false
# Jina Reader API key (optional but recommended — free tier: 1M tokens/month)
#   Sign up: https://jina.ai/reader/
JINA_API_KEY=
WEB_FETCH_TIMEOUT=15
WEB_FETCH_MAX_KB=100

# ══════════════════════════════════════════════════════════════════
#  SCHEDULED TASKS — cron-like recurring tasks
# ══════════════════════════════════════════════════════════════════

SCHEDULER_ENABLED=false
SCHEDULED_TASKS_FILE=

# ══════════════════════════════════════════════════════════════════
#  LINK UNDERSTANDING — auto-fetch URL content in messages
# ══════════════════════════════════════════════════════════════════

LINK_UNDERSTANDING_ENABLED=true
LINK_MAX_LINKS=3
LINK_FETCH_TIMEOUT=10
# Max content size per link in KB
LINK_MAX_CONTENT_KB=50

# ══════════════════════════════════════════════════════════════════
#  WATCHDOG — self-improving code monitor
# ══════════════════════════════════════════════════════════════════

WATCHDOG_ENABLED=true
WATCHDOG_DRY_RUN=true
WATCHDOG_SCAN_INTERVAL=30
WATCHDOG_MAX_FIXES_HOUR=3
WATCHDOG_FIX_COOLDOWN=1800
WATCHDOG_CLAUDE_MODEL=sonnet
WATCHDOG_BOT_SERVICE=com.claude.chat-bot
