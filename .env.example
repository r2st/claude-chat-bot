# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Mode: "cli" (uses claude CLI) or "api" (uses Anthropic API)
CLAUDE_MODE=cli

# API mode settings (only needed when CLAUDE_MODE=api)
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096
SYSTEM_PROMPT=You are a helpful assistant accessible via Telegram.

# CLI mode: working directory for claude (default: home directory)
CLAUDE_CLI_WORK_DIR=/Users/you
# CLI mode: extra directories claude can access (comma-separated)
CLAUDE_CLI_ADD_DIRS=/Users/you/projects,/Users/you/documents
# CLI mode: permission mode (empty = default, or: acceptEdits, auto, bypassPermissions)
CLAUDE_CLI_PERMISSION_MODE=auto
# CLI mode: default model (haiku, sonnet, opus)
CLAUDE_CLI_MODEL=sonnet
# CLI mode: timeout in seconds (default: 120)
CLAUDE_TIMEOUT=120

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=
